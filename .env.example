# App
NEXT_PUBLIC_APP_NAME="asliCo's Toolkit"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Single-user access (only this email can sign in)
ALLOWED_EMAIL=you@email.com
NEXT_PUBLIC_ALLOWED_EMAIL=you@email.com

# Auth: magic link is default. Passkeys need one RP ID per domain — keep off unless you accept that.
# NEXT_PUBLIC_PASSKEY_ENABLED=true

# Emergency login bypass — off by default. Never enable on production.
# ALLOW_SETUP=true

# Server-only — service_role for ALLOW_SETUP bypass only
SUPABASE_SERVICE_ROLE_KEY=

# Database — optional if using Drizzle directly (Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# AI (Phase 1+)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Speech-to-text (Claude cannot read audio — Deepgram transcribes, Claude summarizes)
DEEPGRAM_API_KEY=

# Self Therapy TTS (ElevenLabs — calm multilingual voice)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Storage (Phase 1+)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Redis / Queue (Phase 1+)
UPSTASH_REDIS_URL=

# Cron / nightly job discovery (optional)
CRON_SECRET=

# Gmail outreach (Job Agent cold email after submit)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Google Cloud Console → OAuth client → Authorized redirect URIs exactly
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback
# Calendar OAuth (add this redirect URI in Google Cloud too)
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/auth/google-calendar/callback
# Backend-only (recommended): paste refresh token once — no browser OAuth after that
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=

# Microsoft / Outlook calendar
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_CALENDAR_REDIRECT_URI=http://localhost:3000/api/auth/microsoft-calendar/callback

# Optional: Indeed/Glassdoor via Adzuna (free — developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Optional: LinkedIn/Indeed/Glassdoor via Jooble (free — jooble.org/api/about)
JOOBLE_API_KEY=
# Optional: developer jobs API (findwork.dev/developers)
FINDWORK_API_KEY=

